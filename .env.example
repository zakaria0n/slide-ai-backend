# Slide AI backend - environment template.
# Copy to `.env` and fill real values. Never commit `.env`.

# --- Environment ---
APP_ENV=development
APP_DEBUG=false

# --- Database (Supabase PostgreSQL) ---
# Option A: provide the full URL (overrides the pieces below).
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Option B: assemble from pieces.
DB_HOST=db.YOUR_PROJECT.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_ECHO=false

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# --- AI provider (internal: OpenCode Zen, shown to users as "Slide AI") ---
AI_PROVIDER_BASE_URL=https://opencode.ai/zen/v1
AI_PROVIDER_API_KEY=public
AI_PROVIDER_DEFAULT_MODEL=deepseek-v4-flash-free
AI_ALLOWED_MODELS=["deepseek-v4-flash-free"]
AI_REQUEST_TIMEOUT_SECONDS=60

# --- Security ---
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
